model Product {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  price       Int
  imageUrl    String?
  sold        Int?     @default(0)
  rating      Float?
  categoryId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    Category @relation(fields: [categoryId], references: [id])
}
